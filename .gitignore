#################################
#           Generals            #
#################################

# idea / editor
.idea/
.pycharm/
.vscode/
*.iml
*.swp
*.swo


# OS
.DS_Store
Thumbs.db
Desktop.ini

# Virtual ENV
.venv/
.uv-venv/
.pip-cache/
.uv-cache/

# npm lock ignores
node_modules/

# Local Data
# Ignore all contents of /data except .gitkeep
/.data/*
!/.data/.gitkeep

# local / Personal  Files
path_util.py

# docs backup
docs/**/*.bkp
docs/**/*.dtmp

# Env files
.env
.env.*

#################################
#       Official Python         #
#################################
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[codz]
*$py.class

# Ruff / Pyright
.ruff_cache/
.pyright/

# unwanted cache
.mypy_cache/
.pyre/
.pytype/
.ipynb_checkpoints/

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#   Usually these files are written by a python script from a template
#   before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal


##################################
#   official Terraform ignores   #
##################################
# Local .terraform directories
.terraform/
*.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc
