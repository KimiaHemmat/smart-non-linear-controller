# Enforce LF for scripts, configs, and source files
*.sh        text eol=lf
*.env       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.tf        text eol=lf
*.tfvars    text eol=lf
*.conf      text eol=lf
*.ini       text eol=lf
*.bkp       text eol=lf
*.drawio    text eol=lf
Dockerfile  text eol=lf

# Python + project files
*.py        text eol=lf
*.toml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.hcl       text eol=lf
.gitlab-ci.yml text eol=lf

# Windows-native scripts
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Default fallback
*           text=auto eol=lf
